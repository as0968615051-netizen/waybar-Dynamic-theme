{
    "layer": "top",
    "position": "top",
    "height": 26,
    "margin-top": 5,
    "spacing": 8,
    "modules-left": ["hyprland/workspaces", "custom/download"],
    "modules-center": ["group/center-drawer"],
    "modules-right": ["custom/media", "cpu", "memory", "battery"],

    "hyprland/workspaces": {
        "format": "{id}",
        "persistent-workspaces": { "*": [1, 2, 3, 4] }
    },

"group/center-drawer": {
    "orientation": "horizontal",
    "drawer": {
        "transition-duration": 500,
        "transition-left-to-right": true
    },
    "modules": [
        "clock",
    ]
},

    "clock": {
        "format": " {:%H:%M}",
        "tooltip": false
    },

    "hyprland/window": {
        "format": " {title}",
        "max-length": 35,
        "separate-outputs": true
    },

    "cpu": { "interval": 2, "format": " {usage}%" },
    "memory": { "interval": 1, "format": " {used:0.1f}G" },
    "battery": { "interval": 10, "format": "{icon} {capacity}%", "format-icons": ["", "", "", "", ""] }
}
